pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
-- beltshooter
-- by neil popham

-- set palette
poke(0x5f2e, 1)
pal({ [0] = 0, -15, -4, 12, 8, 14, 3, 11, 5, 6, -12, 4, -7, -9, -16, 7 }, 1)

_G = _ENV

class = setmetatable(
    {
        new = function(_ENV, tbl)
            return setmetatable(tbl or {}, { __index = _ENV })
        end
    },
    { __index = _ENV }
)

#include player.lua

player = class:new({
    x = 0,
    y = 0,
    dx = 0,
    dy = 0,
    reset = function(_ENV)
        x = 0
        y = 0
        dx = 0
        dy = 0
    end,
    update = function(_ENV)
        x += dx
        y += dy
    end,
    draw = function(_ENV)
        pset(x, y, 7)
    end
})


function _init()
    bgd = {}
    local pr = 2
    for i = 1, 32 do
        bgd[i] = mid(0, flr(rnd(3)) - 1 + pr, 4)
        pr = bgd[i]
    end
    cx = 0
end

function _update60()
    -- homing:update()
    cx += 1
end

function _draw()
    cls(1)
    camera(cx, 0)
    for i, h in pairs(bgd) do
        rectfill((i - 1) * 32, h * 32, (i - 1) * 32 + 31, 127, 0)
        -- (i -1) * 32, h * 32, h * 32 + 31, 127, 0)
        print(h, (i - 1) * 32, 0, 3)
    end
    camera()
    print(cx, 0, 120, 9)
    -- rectfill(64, 64, 127, 127, 0)
    -- homing:draw()
end

