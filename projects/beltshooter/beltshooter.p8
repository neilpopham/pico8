pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
-- beltshooter
-- by neil popham

-- set palette
poke(0x5f2e, 1)
pal({ [0] = 0, -15, -4, 12, 8, 14, 3, 11, 5, 6, -12, 4, -7, -9, -16, 7 }, 1)

_G = _ENV

class = setmetatable(
    {
        new = function(_ENV, tbl)
            return setmetatable(tbl or {}, { __index = _ENV })
        end
    },
    { __index = _ENV }
)

#include player.lua
#include destructables.lua
#include camera.lua
#include levelmaker.lua
#include bullets.lua
#include stages.lua

menuitem(
    1,
    'screenshake on',
    function(b)
        cam.on = not cam.on
        menuitem(nil, 'screenshake ' .. (cam.on and 'on' or 'off'))
        if b < 4 then
            return true
        end
    end
)

function _init()
    stage = stages.game
    stage:init()
end

function _update60()
    stage:update()
end

function _draw()
    cls()
    stage:draw()
    stages:check()
end

