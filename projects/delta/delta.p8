pico-8 cartridge // http://www.pico-8.com
version 43
__lua__

poke(0x5f2d, 1)

x,y,cx,cy,b=0,0,0,0,0

palette = {on = false, x = 101, y = 5, h = 66}

function _update60()
    cx = stat(32)\6
    cy = stat(33)\6
    b = stat(34)

    x = cx * 6 + 1
    y = cy * 6 + 1

end

function _draw()
    cls()

    for i = 1, 127, 6 do
        line(1,i,127,i,1)
    end
    for i = 1, 127, 6 do
        line(i,1,i,127,1)
    end

    if palette.on and x < palette.x then
        palette.on = false
    end

    if palette.on or x > 126 then
        rectfill(palette.x, palette.y, 127, palette.y + palette.h, 0)
        rect(palette.x, palette.y, 127, palette.y + palette.h, 3)
        spr(1,palette.x + 2, palette.y + 2)
        palette.on = true
    end

    if x > 0 and x < 127 and y > 0 and y < 127 then
        if palette.on then
            rect(x - 1, y - 1, x + 6, y + 6, 2)
        else
            -- rect(x, y, x + 6, y + 6, 7)
            spr(5,x,y)
        end
    end

    print(b,0,0,9)
    print(x,10,0,9)
    print(y,30,0,9)
end

