pico-8 cartridge // http://www.pico-8.com
version 43
__lua__

printh("===")

pal(1,0)

_G = _ENV

class = setmetatable(
    {
        new = function(_ENV, tbl)
            return setmetatable(tbl or {}, { __index = _ENV })
        end
    },
    { __index = _ENV }
)

player = class:new({
    p = 0,
    x = 0,
    y = 0,
    dx = 0,
    dy = 0,
    s = 1,
    sx = 0,
    sy = 0,
    -- reset = function(_ENV)
    --     x = 60
    --     y = 60
    --     dx = 0
    --     dy = 0
    -- end,
    update = function(_ENV)
        dx = 0
        dy = 0
        if btn(0, p) then dx = -1 end
        if btn(1, p) then dx = 1 end
        if btn(2, p) then dy = -1 end
        if btn(3, p) then dy = 1 end
        x += dx
        y += dy
    end,
    draw = function(_ENV)
        spr(s, x, y)
    end
})

p1 = player:new({ x = 32, y = 60, p = 0, s = 2 })
-- p1:reset()
p2 = player:new({ x = 40, y = 60, p = 1, s = 3 })
-- p1:reset()

function _update60()
    p1:update()
    p2:update()
end

function _draw()
    cls()

    -- vertical split

    --[[
    clip(0,0,64,128,false)
    camera(p1.x-28,p1.y-60)
    map(0,0)
    p1:draw()
    p2:draw()
    clip(64,0,64,128,false)
    camera(p2.x-92,p2.y-60)
    map(0,0)
    p2:draw()

    clip()
    camera()
    fillp(▒)
    rectfill(63,0,64,127,1)
    print(p2.x,0,0,1)
    --]]

    -- horizontal split
    --[[
    clip(0,0,128,64,false)
    camera(p1.x-60,p1.y-28)
    map(0,0)
    p1:draw()
    p2:draw()
    clip(0,64,128,64,false)
    camera(p2.x-60,p2.y-92)
    map(0,0)
    p2:draw()

    clip()
    camera()
    fillp(▒)
    rectfill(0, 63,127,64,1)
    ]]

    -- no split

    mn = { x = min(p1.x, p2.x), y = min(p1.y, p2.y) }
    mx = { x = max(p1.x, p2.x), y = max(p1.y, p2.y) }

    dx = mx.x - mn.x
    dy = mx.y - mn.y

    assert(dx<64,'dx too large')

    cx = mn.x + dx\2
    cy = mn.y + dy\2

    camera(cx-60,cy-60)
    map(0,0)

    p1:draw()
    p2:draw()

    print(p1.x,0,0,8)
    print(p2.x,20,0,8)
    print(p1.y,0,7,8)
    print(p2.y,20,7,8)
    print(dx, 40, 0, 8)
    print(dy, 40, 7, 8)
end


