pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
--

poke(0x5f2e, 1)
pal({ [0] = 0, -15, -4, 12, 8, 14, 3, 11, 5, 6, -12, 4, -7, -9, -16, 7 }, 1)

function _init()
    bgd = {}
    local pr = 2
    for i = 1, 32 do
        bgd[i] = mid(0, flr(rnd(3)) - 1 + pr, 4)
        pr = bgd[i]
    end

    x = 64
    y = 64
    r = 32

    c = { 15, 13, 12, 11, 10, 14 }

    dt = 0
end

function _update60()
    if btn(0) then
        x -= 1
    end
    if btn(1) then
        x += 1
    end
    if btn(2) then
        y -= 1
    end
    if btn(3) then
        y += 1
    end
    if btn(4) then
        r += 1
    end
    if btn(5) then
        r -= 1
    end
    if dt % 4 == 0 then
        rx = rnd(2) - 1
        ry = rnd(2) - 1
        rr = rnd(2)
    end
    dt += 1
end

function _draw()
    -- pal({ [0] = 0, -15, -4, 12, 8, 14, 3, 11, 5, 6, -12, 4, -7, -9, -16, 7 }, 1)
    -- pal(3, 3, 0)
    -- pal(5, 5, 0)
    -- pal(7, 7, 0)

    poke(0x5f5e, 0b11111111)

    cls(0)
    -- for i, h in pairs(bgd) do
    --     rectfill((i - 1) * 32, h * 32, (i - 1) * 32 + 31, 127, 1)
    --     print(h, (i - 1) * 32, 0, 3)
    -- end
    -- pal(5, 5, 0)
    map()
    -- for i = 1, 15 do
    --     rectfill(i * 8, 0, i * 8 + 7, 127, i)
    -- end
    -- pal(3, 14, 1)
    -- pal(5, 14, 1)
    -- pal(7, 14, 1)
    poke(0x5f5e, 0b11110001)
    circfill(x + rx, y + ry, r + rr, 1)
    poke(0x5f5e, 0b11111111)
    -- pal(14, 14, 1)
    -- pal(14, 14, 1)
    -- pal(14, 14, 1)

    -- circfill(x + 40, y + 40, r, 15)

    -- circfill(20 + rx, 90 + ry, 21 + rr, 14)
    -- circfill(20 + rx, 90 + ry, 18 + rr, 10)
    -- circfill(20 + rx, 90 + ry, 15 + rr, 11)
    -- circfill(20 + rx, 90 + ry, 12 + rr, 12)
    -- circfill(20 + rx, 90 + ry, 9 + rr, 13)
    -- circfill(20 + rx, 90 + ry, 6 + rr, 15)
end

