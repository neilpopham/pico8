pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
--

-- mapsize = { w = 128, h = 32 }

-- b = $0x2000
-- poke4(0x2000 + mapsize.w * 18, b)
-- for b = 0, mapsize.h - 1 do
-- end
-- mx = mapsize.w / 4
-- my = mapsize.h / 2 - 1

-- bs = 0x2000
-- be = 0x2000 + (mapsize.h - 1) * mapsize.w
-- -- printh(be)
-- -- print(peek4(be))
-- for by = 0, my do
--     for bx = 0, mapsize.w - 1, 4 do
--         p1 = bs + (by * mapsize.w) + bx
--         p2 = be - (by * mapsize.w) + bx
--         b1 = peek4(p1)
--         b2 = peek4(p2)
--         poke4(p1, b2)
--         poke4(p2, b1)
--     end
-- end

-- b = $0x2000
-- poke4(be, b)
-- poke4(0x3000, b)

bs = 0x2000
be = 0x1f80 -- 0x1000 + 31 * 128
for by = 0, 31 do
    for bx = 0, 124, 4 do
        p1 = 0x2000 + (by * 128) + bx
        p2 = 0x1f80 - (by * 128) + bx
        b1 = $p1
        poke4(p1, $p2)
        poke4(p2, b1)

        -- p1 = 0x2000 + (by * 128) + bx
        -- p2 = 0x1f80 - (by * 128) + bx
        -- poke4(p1, $p2)
        -- poke4(p2, $p1)
    end
end

x, y = 0, 0

function _update60()
    if btn(0) then
        x -= 8
    end
    if btn(1) then
        x += 8
    end
    if btn(2) then
        y -= 8
    end
    if btn(3) then
        y += 8
    end
end

function _draw()
    cls()
    map()
    camera(x, y)
end

